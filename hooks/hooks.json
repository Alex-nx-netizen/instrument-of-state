{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cmd /d /s /c \"\"${CLAUDE_PLUGIN_ROOT}/bin/instrument-guard.cmd\" session-context\"",
            "timeout": 15
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cmd /d /s /c \"\"${CLAUDE_PLUGIN_ROOT}/bin/instrument-guard.cmd\" reset\""
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "zhongshu-agent|menxia-agent|works-delivery-agent",
        "hooks": [
          {
            "type": "command",
            "command": "cmd /d /s /c \"\"${CLAUDE_PLUGIN_ROOT}/bin/instrument-guard.cmd\" annotate-start\""
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "zhongshu-agent",
        "hooks": [
          {
            "type": "command",
            "command": "cmd /d /s /c \"\"${CLAUDE_PLUGIN_ROOT}/bin/instrument-guard.cmd\" record-zhongshu\""
          }
        ]
      },
      {
        "matcher": "menxia-agent",
        "hooks": [
          {
            "type": "command",
            "command": "cmd /d /s /c \"\"${CLAUDE_PLUGIN_ROOT}/bin/instrument-guard.cmd\" record-menxia\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "cmd /d /s /c \"\"${CLAUDE_PLUGIN_ROOT}/bin/instrument-guard.cmd\" guard-agent\""
          }
        ]
      },
      {
        "matcher": "Write|Edit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cmd /d /s /c \"\"${CLAUDE_PLUGIN_ROOT}/bin/instrument-guard.cmd\" guard-tool\""
          }
        ]
      }
    ]
  }
}
